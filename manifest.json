{
  "manifest_version": 3,
  "name": "FrameRate",
  "version": "1.0.0",
  "description": "High-performance screen capture: frame-by-frame, full-page screenshots, 60fps video recording, and smooth walkthrough videos.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabCapture",
    "offscreen",
    "downloads",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "stop-capture": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Stop active capture or recording"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
